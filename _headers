# Cache-bust JS and CSS: 10 minutes max, must revalidate on each visit
/js/*
  Cache-Control: public, max-age=600, must-revalidate

/css/*
  Cache-Control: public, max-age=600, must-revalidate

# HTML pages: never cache, always fetch fresh
/*.html
  Cache-Control: no-cache

/
  Cache-Control: no-cache

# Security headers — all paths
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Block indexing on admin/internal paths (belt-and-suspenders with HTML noindex)
/polymyth/dmboard/*
  X-Robots-Tag: noindex, nofollow

/polymyth/trace/*
  X-Robots-Tag: noindex, nofollow

/polymyth/notebook/*
  X-Robots-Tag: noindex, nofollow

/data/*
  X-Robots-Tag: noindex, nofollow

/aa/cloud/*
  X-Robots-Tag: noindex, nofollow

/leizu/cloud/*
  X-Robots-Tag: noindex, nofollow

/bookwormcard/print/*
  X-Robots-Tag: noindex, nofollow

/bookwormcard/pdf/*
  X-Robots-Tag: noindex, nofollow

/scripts/*
  X-Robots-Tag: noindex, nofollow

# Immutable assets (fonts, images) — long cache
/img/*
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=2592000

/og-image.png
  Cache-Control: public, max-age=2592000

# JSON data — short cache, revalidate
/*.json
  Cache-Control: public, max-age=300, must-revalidate

# Feed XML — short cache
/polymythseminars/feed.xml
  Cache-Control: public, max-age=3600, must-revalidate
  X-Content-Type-Options: nosniff

/teacherresources/feed.xml
  Cache-Control: public, max-age=3600, must-revalidate

/agora/feed.xml
  Cache-Control: public, max-age=3600, must-revalidate
