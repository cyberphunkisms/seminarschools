  "route_groups": [
    {
      "pattern": "/teacherresources/**/",
      "type": "generated-resource-detail",
      "public": true,
      "source": "data/teacherresources or generated catalog HTML"
    },
    {
      "pattern": "/polymythseminars/events/**/",
      "type": "generated-event-detail",
      "publicOrNoindex": true,
      "source": "polymythseminars/events.json"
    },
    {
      "pattern": "/campaigns/**/",
      "type": "campaign",
      "publicOrNoindex": true
    },
    {
      "pattern": "/polymyth/articles/**/",
      "type": "archive-article",
      "publicOrNoindex": true
    },
    {
      "pattern": "/marginalia/posts/**/",
      "type": "archive-post",
      "publicOrNoindex": true
    }
  ],
  "page_type_contracts": {
    "service": "Service pages make the action path visible first, then keep policy, price, contact, and intake details close enough that a family can decide without reading the whole site.",
    "cv": "CV pages present a broad professional record with clean print behavior, zoom resilience, and no project-only narrowing unless the page title explicitly says it is project-specific.",
    "calendar": "Calendar pages put source links, filters, freshness labels, empty states, and keyboard movement ahead of decorative complexity.",
    "game": "Game pages separate student action, teacher notes, saving/resuming, and research explanation so the play loop stays legible.",
    "archive": "Archive pages preserve source-of-truth density while giving a short route note, anchors, search, and related paths that help readers enter without flattening the archive.",
    "tool": "Tool pages expose the working controls, keyboard hints, loading and empty states, and fallback behavior before any decorative or theoretical layer.",
    "resource-catalog": "Resource catalogs prioritize finding links through search, subject filters, grade and level signals, and stable outbound routes; they avoid unnecessary teacher-decision metadata.",
    "campaign": "Campaign pages keep the public story, call to action, and route status clear while protecting private/system artifacts."
  },
  "anti_twist_rule": "Page-type rules support the existing project meaning. They must not rename, flatten, or reframe ML*, AA*, polymyth, BB, Leizu, or CL in ways that change their function or source-of-truth relation."
}